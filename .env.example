# Copy this file to .env and fill in your values.
# Never commit .env — it contains real API keys.

# ============================================================
# API Keys
# ============================================================

# USDA FoodData Central API key (free at https://fdc.nal.usda.gov/api-key-signup)
USDA_API_KEY=your_usda_api_key_here

# Kaggle (needed only for training scripts — get from https://www.kaggle.com/settings)
KAGGLE_API_TOKEN=your_kaggle_token_here

# ============================================================
# Pipeline tuning (safe defaults — change only if needed)
# ============================================================

# --- Classifier -------------------------------------------------
CLASSIFIER_BACKEND=auto          # auto | efficientnet | clip
EFFNET_FALLBACK_THRESHOLD=0.65
EFFNET_TEMPERATURE=1.6
EFFNET_TTA_LOW=0.50
EFFNET_TTA_HIGH=0.72
EFFNET_TOPK=5

# --- CLIP -------------------------------------------------------
CLIP_PROMPT_ENSEMBLE=1
FOOD_GATE_ENABLED=1
FOOD_GATE_MARGIN=0.0

# --- YOLO Detector ----------------------------------------------
YOLO_CONF=0.10
BLUR_CONF_EXEMPT=0.30
YOLO_IOU=0.35
MIN_BBOX_AREA_PX=600
YOLO_IMGSZ=800
YOLO_TILED=true
YOLO_TTA=false

# --- FastSAM Segmenter ------------------------------------------
FASTSAM_CONF=0.35
FASTSAM_IOU=0.90
FASTSAM_IMGSZ=640

# --- Pipeline Post-processing -----------------------------------
MIN_BBOX_RELATIVE_AREA=0.005
MIN_SEG_SCORE=0.35
MIN_MASK_COVERAGE=0.10
MASK_IOU_DEDUP=0.60
DEDUP_SAME_LABEL_IOU=0.35
DEDUP_SAME_LABEL_SIM=0.62
DEDUP_CROSS_LABEL_IOU=0.88

# --- API Server -------------------------------------------------
GPU_CONCURRENCY=1                # raise to 2 only if VRAM > 12 GB
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
